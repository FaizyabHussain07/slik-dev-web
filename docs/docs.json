{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Slik",
  "logo": {
    "dark": "/logo-dark.svg",
    "light": "/logo-light.svg"
  },
  "theme": "mint",
  "colors": {
    "primary": "#10b981",
    "light": "#34d399",
    "dark": "#059669"
  },
  "favicon": "/favicon.svg",
  "anchors": [
    {
      "anchor": "Slik CLI",
      "href": "https://github.com/FaizyabHussain07/slik-engine",
      "icon": "github",
      "color": "#10b981"
    }
  ],
  "topbarCtaButton": {
    "text": "Try Slik",
    "url": "https://slik-dev.vercel.app/"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub (Web)",
        "href": "https://github.com/FaizyabHussain07/slik-dev-web"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/FaizyabHussain07/slik-dev-web",
      "twitter": "https://x.com/FaizyabHus74391",
      "website": "https://slik-dev.vercel.app/"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "installation"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "configuration/stacks",
              "configuration/themes",
              "configuration/auth",
              "configuration/database"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/first-project",
              "guides/customizing-ui",
              "guides/adding-pages",
              "guides/deploying"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/cli",
              "reference/tech-stack",
              "reference/faq"
            ]
          }
        ]
      }
    ]
  }
}
