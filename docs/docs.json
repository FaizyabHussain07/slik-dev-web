{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Slik",
  "logo": {
    "dark": "/logo-dark.png",
    "light": "/logo-light.png"
  },
  "theme": "luma",
  "colors": {
    "primary": "#10b981",
    "light": "#34d399",
    "dark": "#059669",
    "background": {
      "dark": "#09090b",
      "light": "#ffffff"
    }
  },
  "favicon": "/favicon.png",
