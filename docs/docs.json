    "name": "Try Slik",
    "url": "https://slik-dev.vercel.app/"
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://slik-dev.vercel.app"
      },
      {
        "label": "GitHub",
        "href": "https://github.com/FaizyabHussain07/slik-dev-web"
      }
    ]
  },
  "footer": {
    "links": [
      {
        "label": "Website",
        "href": "https://slik-dev.vercel.app"
      },
      {
        "label": "GitHub",
        "href": "https://github.com/FaizyabHussain07/slik-dev-web",
        "icon": "github"
      },
      {
        "label": "Twitter",
        "href": "https://twitter.com/faizyabhussain",
        "icon": "twitter"
      }
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
